# ORBI City Hub - Environment Variables Template
# Copy this file to .env and fill in your actual values

# App Configuration
VITE_APP_TITLE="ORBI City Hub"
VITE_APP_LOGO="/logo.png"

# OAuth Configuration
VITE_OAUTH_PORTAL_URL="https://oauth.example.com"
VITE_APP_ID="orbi-city-hub"

# Supabase Configuration
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-publishable-key-here"

# Forge API Configuration
VITE_FRONTEND_FORGE_API_KEY="your-forge-api-key-here"
VITE_FRONTEND_FORGE_API_URL="https://forge.butterfly-effect.dev"

# Analytics Configuration
VITE_ANALYTICS_ENDPOINT="https://analytics.example.com"
VITE_ANALYTICS_WEBSITE_ID="orbi-city-hub"

# Database Configuration (Server-side)
DATABASE_URL="mysql://user:password@localhost:3306/orbi_city_hub"

# Server Configuration
PORT=5000
NODE_ENV="development"
